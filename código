public interface ItemMenu {
    String getTexto();
    String getLink();
    List<ItemMenu> getHijos();
}
public class ItemMenuSimple implements ItemMenu {

    private String texto;
    private String link;

    public ItemMenuSimple(String texto, String link) {
        this.texto = texto;
        this.link = link;
    }

    @Override
    public String getTexto() {
        return texto;
    }

    @Override
    public String getLink() {
        return link;
    }

    @Override
    public List<ItemMenu> getHijos() {

        return List.of();
    }
}
public class ItemMenuCompuesto implements ItemMenu {

    private String texto;
    private String link;
    private List<ItemMenu> hijos = new ArrayList<>();

    public ItemMenuCompuesto(String texto, String link) {
        this.texto = texto;
        this.link = link;
    }

    public void agregarHijo(ItemMenu item) {
        hijos.add(item);
    }

    @Override
    public String getTexto() {
        return texto;
    }

    @Override
    public String getLink() {
        return link;
    }

    @Override
    public List<ItemMenu> getHijos() {
        return hijos;
    }
}
@ControllerAdvice
public class MenuControllerAdvice {

    private final CategoriaService categoriaService;

    public MenuControllerAdvice(CategoriaService categoriaService) {
        this.categoriaService = categoriaService;
    }

    @ModelAttribute("menu")
    public List<ItemMenu> menu() {

        List<ItemMenu> menu = new ArrayList<>();

        menu.add(new ItemMenuSimple("Inicio", "/"));

        ItemMenuCompuesto categoriasMenu =
                new ItemMenuCompuesto("Categorías", "/categoria");

        var categorias = categoriaService.obtenerTodas();

        for (Categoria c : categorias) {

            ItemMenuSimple item = new ItemMenuSimple(
                    c.getNombre(),
                    "/categoria/" + c.getId() + "/" +
                    Slugger.slug(c.getNombre())
            );

            categoriasMenu.agregarHijo(item);
        }

        menu.add(categoriasMenu);
        menu.add(new ItemMenuSimple("Ubicación", "/ubicacion"));
        menu.add(new ItemMenuSimple("Contacto", "/contacto"));

        return menu;
    }
}
public class AvisoAdapter {

    public static Aviso convertir(
            Producto producto,
            int stockTotal,
            Categoria categoria
    ) {
        Aviso aviso = new Aviso();

        aviso.setTitulo(producto.getNombre());
        aviso.setSku(producto.getSku());
        aviso.setPrecio(producto.getCosto() * 1.3); // +30%
        aviso.setImagen(producto.getImagen());
        aviso.setStock(stockTotal);
        aviso.setCategoria(categoria);

        return aviso;
    }
}
@Controller
public class TiendaController {

    private final ProductoService productoService;
    private final BodegajeService bodegajeService;
    private final CategoriaService categoriaService;

    public TiendaController(
            ProductoService productoService,
            BodegajeService bodegajeService,
            CategoriaService categoriaService
    ) {
        this.productoService = productoService;
        this.bodegajeService = bodegajeService;
        this.categoriaService = categoriaService;
    }

    @GetMapping("/")
    public String inicio(Model model) {

        List<Producto> productos = productoService.obtenerTodos();
        List<Aviso> avisos = new ArrayList<>();

        for (Producto p : productos) {

            int stock = bodegajeService.obtenerStockTotal(p.getId());
            Categoria categoria =
                    categoriaService.buscarPorId(p.getCategoriaId());

            avisos.add(
                AvisoAdapter.convertir(p, stock, categoria)
            );
        }

        model.addAttribute("avisos", avisos);
        return "inicio";
    }

    @GetMapping("/categoria/{categoriaId}/{slug}")
    public String categoria(
            @PathVariable Long categoriaId,
            @PathVariable String slug,
            Model model
    ) {

        Categoria categoria =
                categoriaService.buscarPorId(categoriaId);

        List<Producto> productos =
                productoService.buscarPorCategoria(categoriaId);

        List<Aviso> avisos = new ArrayList<>();

        for (Producto p : productos) {

            int stock = bodegajeService.obtenerStockTotal(p.getId());

            avisos.add(
                AvisoAdapter.convertir(p, stock, categoria)
            );
        }

        model.addAttribute("avisos", avisos);
        model.addAttribute("categoria", categoria);

        return "categoria";
    }
}
